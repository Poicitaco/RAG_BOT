# Application Settings
APP_NAME="Pharmaceutical AI Assistant"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True
LOG_LEVEL="INFO"

# API Server
HOST="0.0.0.0"
PORT=8000
WORKERS=4

# OpenAI API
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# Anthropic API (Alternative)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
ANTHROPIC_MODEL="claude-3-opus-20240229"

# Database PostgreSQL
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="pharma_ai"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis Cache
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# Vector Store
VECTOR_STORE_TYPE="chromadb"  # chromadb, faiss, pinecone
CHROMA_PERSIST_DIR="./data/embeddings/chroma"
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="your-pinecone-environment"

# RAG Settings
EMBEDDING_DIMENSION=1536
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# Agent Settings
MAX_ITERATIONS=10
AGENT_TIMEOUT=300
ENABLE_MEMORY=True

# Multi-modal Settings
ENABLE_IMAGE_RECOGNITION=True
ENABLE_VOICE_INPUT=True
ENABLE_VOICE_OUTPUT=True
MAX_IMAGE_SIZE=10485760  # 10MB
SUPPORTED_IMAGE_FORMATS="jpg,jpeg,png,webp"
SUPPORTED_AUDIO_FORMATS="mp3,wav,ogg,m4a"

# Safety & Compliance
ENABLE_SAFETY_CHECK=True
ENABLE_INTERACTION_WARNING=True
ENABLE_DOSAGE_VALIDATION=True
REQUIRE_MEDICAL_DISCLAIMER=True

# Monitoring
ENABLE_PROMETHEUS=True
PROMETHEUS_PORT=9090
SENTRY_DSN=""

# Security
SECRET_KEY="your-secret-key-here-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS="http://localhost:3000,http://localhost:8501"

# File Storage
UPLOAD_DIR="./data/uploads"
MAX_UPLOAD_SIZE=52428800  # 50MB

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================
# LOCAL AI CONFIGURATION (Không cần API key!)
# ============================================================

# AI Mode: "local" (chạy local) hoặc "openai" (dùng API)
AI_MODE="openai"  # Đổi sang "local" để dùng AI local

# ============= Ollama LLM Settings =============
OLLAMA_BASE_URL="http://localhost:11434"

# LLM model (chọn 1):
# - mistral:7b-instruct (4.1GB) - Cân bằng, khuyến nghị
# - qwen2.5:7b (4.7GB) - Tốt nhất cho tiếng Việt
# - gemma2:9b (5.4GB) - Nhanh nhất
# - llama3.1:8b (4.7GB) - Tốt all-around
OLLAMA_MODEL="mistral:7b-instruct"

# Embedding model cho Ollama
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=2048

# ============= Local Embeddings Settings =============
# Models tiếng Việt:
# - keepitreal/vietnamese-sbert (khuyến nghị)
# - VoVanPhuc/sup-SimCSE-VietNamese-phobert-base
# - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_MODEL="keepitreal/vietnamese-sbert"
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE="cuda"  # cuda, cpu, mps

# ============= Local Whisper Settings =============
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE="base"
WHISPER_DEVICE="cuda"  # cuda hoặc cpu
WHISPER_COMPUTE_TYPE="float16"  # float16, int8, int8_float16
WHISPER_LANGUAGE="vi"  # vi, en

# ============= Performance Settings =============
USE_GPU=True
MAX_CONCURRENT_REQUESTS=5
MODEL_CACHE_DIR="./models_cache"
